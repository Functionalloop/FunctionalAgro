# FunctionalAgro Environment Variables
# Copy this file to .env and fill in your keys

# ── Required ──────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com (free tier, no billing required)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# Set to true on judging day as insurance: bypasses ALL LLM calls, returns
# hardcoded responses. Everything else (diagnosis, outbreak, map) still works.
DEMO_MODE=false

# ── Outbreak Detection Tuning ─────────────────────────────────────────────────
# Number of same-disease reports to trigger an outbreak alert (default: 3)
OUTBREAK_THRESHOLD=3
# Lookback window in days (default: 7)
OUTBREAK_WINDOW_DAYS=7

# ── Bhashini (Translation + TTS) ──────────────────────────────────────────────
# Register at: https://bhashini.gov.in
# Without these, the app falls back to Google Translate (deep-translator) + gTTS
BHASHINI_API_KEY=your_bhashini_api_key_here
BHASHINI_USER_ID=your_bhashini_user_id_here
